# Google OAuth Client ID (requis pour l'import Gmail)
# 1. Va sur https://console.cloud.google.com
# 2. Crée un projet > APIs & Services > Credentials
# 3. Crée un OAuth 2.0 Client ID (type: Web application)
# 4. Ajoute http://localhost:5173 dans Authorized JavaScript origins
# 5. Copie le Client ID ici
VITE_GOOGLE_CLIENT_ID=ton_client_id_google.apps.googleusercontent.com

# Anthropic API Key (requis en prod sur Vercel)
# 1. Va sur https://console.anthropic.com
# 2. API Keys > Create Key
# 3. Ajoute cette variable dans les settings Vercel (pas dans .env local)
ANTHROPIC_API_KEY=sk-ant-...

# Claude model version (optional, defaults to claude-haiku-4-5-20251001)
# Update this when Claude versions change to maintain compatibility
VITE_CLAUDE_MODEL=claude-haiku-4-5-20251001

# Adzuna API (optionnel - recherche d'offres)
# Gratuit: https://developer.adzuna.com/
VITE_ADZUNA_APP_ID=ton_app_id
VITE_ADZUNA_APP_KEY=ton_app_key

# Supabase Configuration (v1.0 - Multi-device sync)
# 1. Create project at https://supabase.com
# 2. Go to Project Settings > API to get these values
# 3. Install Supabase CLI: npm install -g supabase
# 4. Run migrations: supabase migration up
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
