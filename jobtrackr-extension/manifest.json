{
  "manifest_version": 2,
  "name": "JobTrackr",
  "version": "1.5.0",
  "description": "Ajoute une offre d'emploi à JobTrackr en 1 clic + Autofill IA des formulaires de candidature",
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png",
      "96": "icons/icon96.png"
    },
    "default_title": "JobTrackr"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "homepage_url": "https://jobtracking-three.vercel.app",
  "developer": {
    "name": "Alexandre Leblanc",
    "url": "https://jobtracking-three.vercel.app"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "jobtrackr@deviloufr.dev",
      "strict_min_version": "109.0"
    }
  }
}
