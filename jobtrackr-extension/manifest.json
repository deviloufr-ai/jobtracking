{
  "manifest_version": 2,
  "name": "JobTrackr — Capture d'offres",
  "version": "1.0.0",
  "description": "Capturez une offre d'emploi depuis n'importe quelle page et ajoutez-la à JobTrackr en un clic. Extraction automatique via IA.",
  "author": "Alexandre Leblanc",

  "browser_specific_settings": {
    "gecko": {
      "id": "jobtrackr@deviloufr.com",
      "strict_min_version": "109.0"
    },
    "gecko_android": {},
    "data_collection_permissions": {
      "required": [],
      "optional": []
    }
  },

  "permissions": [
    "activeTab"
  ],

  "icons": {
    "48":  "icons/icon-48.svg",
    "96":  "icons/icon-96.svg",
    "128": "icons/icon-128.svg"
  },

  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_title": "JobTrackr — Capturer cette offre",
    "default_icon": {
      "48":  "icons/icon-48.svg",
      "96":  "icons/icon-96.svg"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "content_security_policy": "script-src 'self'; object-src 'self'"
}
